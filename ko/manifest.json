    "remaining_missing": [
      {
        "namespace": "/Game/Data/ExportDialogues/BigWorldBl01L1/BigWorldBl01L1_SSR/ShuoShuChangZhuTest/DT_DialogueInfo_BigWorldBl01L1_SSR_ShuoShuChangZhuTest",
        "guid": "BigWorldBl01L1_SSR_ShuoShuChangZhuTest_11_ShuoShuRenAnYu_DialogueText",
        "source_text": "嗬，墙上字画虽粗陋，题着“快意恩仇”四字，笔力遒劲，倒也不俗。"
      },
      {
        "namespace": "/Game/Data/ExportDialogues/BigWorldCl02/BigWorldCl02_XZFWNPC/WanShangKanShuMoDaoNan/DT_DialogueInfo_BigWorldCl02_XZFWNPC_WanShangKanShuMoDaoNan",
        "guid": "BigWorldCl02_XZFWNPC_WanShangKanShuMoDaoNan_03_HuZhiXue_DialogueText",
        "source_text": "是本记载术印范例的参考书……"
      },
      {
        "namespace": "/Game/Data/ExportDialogues/CQu/CQu_C171/FuJieXunLiu/DT_DialogueInfo_CQu_C171_FuJieXunLiu",
        "guid": "CQu_C171_FuJieXunLiu_05_ZhuGeLiang_DialogueText",
        "source_text": "我们应该将其流向玄雍之事告知给汪某，让他无法辩驳，动摇他内心防御底线。"
      },
      {
        "namespace": "/Game/Data/ExportDialogues/CQu/CQu_C89LYYYX/Di4Duan/DT_DialogueInfo_CQu_C89LYYYX_Di4Duan",
        "guid": "CQu_C89LYYYX_Di4Duan_47_DialogueText",
        "source_text": "物趣。"
      },
      {
        "namespace": "/Game/Data/ExportDialogues/CQu/CQu_GOHOME4/XianZhiDuiHua/DT_DialogueInfo_CQu_GOHOME4_XianZhiDuiHua",
        "guid": "CQu_GOHOME4_XianZhiDuiHua_01_QiZai_DialogueText",
        "source_text": "轻轻软软的萤公丁，摸起来一定很舒服……"
      },
      {
        "namespace": "/Game/Data/ExportDialogues/B/B_B121LGKX/MuQinYuXiaoNvHai2/DT_DialogueInfo_B_B121LGKX_MuQinYuXiaoNvHai2",
        "guid": "DT_DialogueInfo_B_B121LGKX_MuQinYuXiaoNvHai2_DialogueSummary_DialogueText",
        "source_text": "重新亮起的灯光帮助了来往的行人，也打动了刚晨。他决定加入修灯的行列，并建议你去善生庭那边看看。"
      },
      {
        "namespace": "/Game/Data/ExportDialogues/BigworldSq/BigworldSq_GC/CKunYouXiongXiaoSan/DT_DialogueInfo_BigworldSq_GC_CKunYouXiongXiaoSan",
        "guid": "DT_DialogueInfo_BigworldSq_GC_CKunYouXiongXiaoSan_DialogueSummary_DialogueText",
        "source_text": "躁动的丁午亥归于平静，展示出一片瑰丽的画面——魔道变化出的漫天极光之下，诸葛亮与司马懿并肩而立——若眼前的世界只剩黑白，你我变当凭双手，造自己的光。"
      },
      {
        "namespace": "/Game/Data/ExportDialogues/SunBinYaoYue/SunBinYaoYue_SBYY/DuiHua2/DT_DialogueInfo_SunBinYaoYue_SBYY_DuiHua2",
        "guid": "DT_DialogueInfo_SunBinYaoYue_SBYY_DuiHua2_DialogueSummary_DialogueText",
        "source_text": "跟着喵帅，你们在屋顶上发现那只躲起来的猫，去把它抱下来吧。"
      },
      {
        "namespace": "/Game/Data/ExportDialogues/ReactionPetTth/ReactionPetTth_DDFK/WanJiaKaoJinPengRenTai1/DT_DialogueInfo_ReactionPetTth_DDFK_WanJiaKaoJinPengRenTai1",
        "guid": "ReactionPetTth_DDFK_WanJiaKaoJinPengRenTai1_00_Character11_DialogueText",
        "source_text": "美食的秘诀是要敢下料！主人，来试试以毒攻毒！"
      },
      {
        "namespace": "/Game/Data/ExportDialogues/S7Test/S7Test_DJZCSTC/HuiHe/DT_DialogueInfo_S7Test_DJZCSTC_HuiHe",
        "guid": "S7Test_DJZCSTC_HuiHe_13_PlayerF_DialogueText",
        "source_text": "庄周老师说在我身上看到一个圆。"
      },
      {
        "namespace": "/Game/Data/ExportDialogues/XuanShang/XuanShang_583002/JieQuDuiHua/DT_DialogueInfo_XuanShang_583002_JieQuDuiHua",
        "guid": "XuanShang_583002_JieQuDuiHua_05_FanYi1_DialogueText",
        "source_text": "至于如何观察……云丝传像能帮助我们观察到活物的骨骼、经络、肌肉构造等。"
      }
    ],
